# --- LLM / Embedding provider ---
OPENAI_API_KEY=sk-...

# --- Embedding model ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Vector store ---
CHROMA_PERSIST_DIR=./data/vector_store
CHROMA_COLLECTION_NAME=evangelist_kb

# --- Scraping ---
SCRAPE_USER_AGENT=CRAG-BOT/1.0 (+https://evangelistsoftware.com)
SCRAPE_REQUEST_DELAY_SEC=1.0
SCRAPE_MAX_RETRIES=3
SCRAPE_TIMEOUT_SEC=30

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Source ---
SITEMAP_INDEX_URL=https://evangelistsoftware.com/sitemap_index.xml
